  "scripts": {
    "=================================================================ANDROID=========================================================================": "ANDROID",
    "=================================================================ANDROID==========================================================================": "ANDROID",
    "=================================================================ANDROID===========================================================================": "ANDROID",
    "=========================================================================": "NOTE 4 (my-android) - PHONE",
    "list-androids": "adb devices",
    "my-android": "react-native run-android  --device R3CMC035PHN",
    "=========================================================================": "GALAXY S22 (load-galaxys22 - android-galaxys22) - LOAD AVD & RUN APP",
    "list-avds": "emulator -list-avds",
    "load-galaxys22": "emulator -avd Galaxy_S22_API_34 -port 5554 -no-snapshot-load &",
    "android-galaxys22": "npx react-native run-android --device emulator-5554",
    "=========================================================================": "PIXEL 8 AVD (android) - PICKS 1ST AVAILABLE",
    "android": "react-native run-android",
    "=========================================================================": "DEBUGGING",
    "reload-androids": "adb shell input keyevent 82",
    "===================================================================iOS=========================================================================": "iOS",
    "===================================================================iOS==========================================================================": "iOS",
    "===================================================================iOS===========================================================================": "iOS",
    "========================================================================": "iPHONE 16 PRO MAX (my-iphone) - PHONE",
    "list-iphones": "xcrun xctrace list devices",
    "my-iphone": "react-native run-ios --device 'Carlo’s iPhone'",
    "========================================================================": "iPHONE 17 PRO MAX (ios-17promax) SIMULATOR ",
    "ios-17promax": "react-native run-ios --simulator 'iPhone 17 Pro Max'",
    "========================================================================": "iPHONE 15 (ios) - PICKS 1ST AVAILABLE",
    "ios": "react-native run-ios",
    "==================================================================METRO========================================================================": "METRO",
    "start": "react-native start",
    "start-reset": "react-native start --reset-cache",
    "==================================================================TESTS==========================================================================": "TESTS",
    "lint": "eslint .",
    "test": "jest"
  },
